#!/bin/bash
# ==============================================================================
# PIPELINE: pilot-control
# Purpose: Master utility tool for toggling Pilot HUD specific overrides
# ==============================================================================

show_help() {
    clear
    echo -e "\033[1;36m"
    echo "  в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•— в–Ҳв–Ҳв•—в–Ҳв–Ҳв•—      в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•— в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—"
    echo "  в–Ҳв–Ҳв•”в•җв•җв–Ҳв–Ҳв•—в–Ҳв–Ҳв•‘в–Ҳв–Ҳв•‘     в–Ҳв–Ҳв•”в•җв•җв•җв–Ҳв–Ҳв•—в•ҡв•җв•җв–Ҳв–Ҳв•”в•җв•җв•қ"
    echo "  в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•”в•қв–Ҳв–Ҳв•‘в–Ҳв–Ҳв•‘     в–Ҳв–Ҳв•‘   в–Ҳв–Ҳв•‘   в–Ҳв–Ҳв•‘   "
    echo "  в–Ҳв–Ҳв•”в•җв•җв•җв•қ в–Ҳв–Ҳв•‘в–Ҳв–Ҳв•‘     в–Ҳв–Ҳв•‘   в–Ҳв–Ҳв•‘   в–Ҳв–Ҳв•‘   "
    echo "  в–Ҳв–Ҳв•‘     в–Ҳв–Ҳв•‘в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—в•ҡв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•”в•қ   в–Ҳв–Ҳв•‘   "
    echo "  в•ҡв•җв•қ     в•ҡв•җв•қв•ҡв•җв•җв•җв•җв•җв•җв•қ в•ҡв•җв•җв•җв•җв•җв•қ    в•ҡв•җв•қ   "
    echo -e "\033[1;33m       MASTER CONTROL PROTOCOL\033[0m"
    echo ""
    echo -e "\033[1;37mUsage: \033[1;32mpilot-control <module> [action]\033[0m"
    echo ""
    echo -e "\033[1;34m[ MODULES ]\033[0m"
    echo "  sddm     Manage the Cinematic Login HUD"
    echo ""
    echo -e "\033[1;34m[ ACTIONS FOR 'sddm' ]\033[0m"
    echo -e "  \033[1;32m--engage\033[0m     Force-links the Cinematic Theme overrides"
    echo -e "  \033[1;31m--disengage\033[0m  Removes all HUD overrides; resets to Civilian Defaults"
    echo -e "  \033[1;33m--status\033[0m     Check the integrity of current protocols"
    echo ""
    echo -e "\033[0;90mNote: Some commands require sudo authorization for system clearance.\033[0m"
    echo ""
}

case "$1" in
    sddm)
        SCRIPT_PATH=$(readlink -f "$0")
        REPO_DIR=$(dirname "$(dirname "$(dirname "$(dirname "$SCRIPT_PATH")")")")

        case "$2" in
            --engage)
                echo -e "\033[1;34m>> Engaging Cinematic Priority Override...\033[0m"
                sudo mkdir -p /etc/sddm.conf.d
                sudo ln -sf "$REPO_DIR/core/sddm/sddm.conf.d/00-theme.conf" "/etc/sddm.conf.d/00-theme.conf"
                echo -e "\033[1;32mвң… Protocol Active. Login HUD is now in Combat Mode.\033[0m"
                ;;
            --disengage|--restore)
                echo -e "\033[1;31m>> Disengaging Cinematic Protocols...\033[0m"
                if [ -L "/etc/sddm.conf.d/00-theme.conf" ] || [ -f "/etc/sddm.conf.d/00-theme.conf" ]; then
                    sudo rm -f "/etc/sddm.conf.d/00-theme.conf"
                    echo -e "\033[1;32mвң… Priority links purged. SDDM is returning to Civilian Defaults.\033[0m"
                else
                    echo -e "\033[1;33mвҡ пёҸ No override found. System is already clear.\033[0m"
                fi
                ;;
            --status)
                if [ -L "/etc/sddm.conf.d/00-theme.conf" ] || [ -f "/etc/sddm.conf.d/00-theme.conf" ]; then
                    echo -e "Protocol Status: \033[1;31mENGAGED рҹҡҖ\033[0m"
                    echo "Cinematic Login Theme is active."
                else
                    echo -e "Protocol Status: \033[1;34mCIVILIAN рҹҸ \033[0m"
                    echo "No overrides detected. Standard SDDM theme is active."
                fi
                ;;
            *)
                echo -e "\033[1;31mUnknown action for sddm: $2\033[0m"
                echo "Use --engage, --disengage, or --status"
                exit 1
                ;;
        esac
        ;;
    *)
        show_help
        ;;
esac

