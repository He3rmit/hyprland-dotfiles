{
  "$schema": "/etc/xdg/swaync/configSchema.json",
  "positionX": "right",
  "positionY": "bottom",
  "control-center-width": 600,
  "notification-window-width": 500,
  "fit-to-screen": false,
  "layer": "overlay",
  "control-center-layer": "overlay",
  "cssPriority": "user",
  "notification-body-image-height": 100,
  "notification-body-image-width": 200,
  "timeout": 5,
  "timeout-low": 2,
  "timeout-critical": 0,
  "widgets": [
    "title",
    "dnd",
    "buttons-grid",
    "backlight",
    "volume",
    "mpris",
    "notifications"
  ],
  "widget-config": {
    "title": {
      "text": "PILOT HUD",
      "clear-all-button": true,
      "button-text": "PURGE"
    },
    "dnd": {
      "text": "Do Not Disturb"
    },
    "buttons-grid": {
      "buttons-per-row": 3,
      "actions": [
        {
          "label": "󰖩",
          "command": "nm-connection-editor",
          "active": false
        },
        {
          "label": "󰂯",
          "command": "blueman-manager",
          "active": false
        },
        {
          "label": "󱛄",
          "command": "wihotspot-gui",
          "active": false
        },
        {
          "label": "󰓅",
          "command": "~/.config/swaync/scripts/power-profile-cycle.sh",
          "active": false
        },
        {
          "label": "󰕾",
          "command": "~/.config/swaync/scripts/volume.sh toggle",
          "active": false
        },
        {
          "label": "󰄄",
          "command": "~/.config/hypr/scripts/screenshot-swappy.sh",
          "active": false
        },
        {
          "label": "󰍺",
          "command": "~/.config/hypr/scripts/mirror-hotplug.sh",
          "active": false
        },
        {
          "label": "󰉋",
          "command": "dolphin",
          "active": false
        },
        {
          "label": "󰅇",
          "command": "~/.config/hypr/scripts/cliphist-rofi.sh",
          "active": false
        }
      ]
    },
    "volume": {
      "label": "󰕾",
      "show-per-app": true,
      "show-per-app-icon": true,
      "show-per-app-label": false
    },
    "backlight": {
      "label": "󰃠"
    },
    "mpris": {
      "image-size": 96
    },
    "notifications": {}
  }
}